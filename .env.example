# ── Backend secrets — copy to `backend/.env.local` (never commit secrets) ────
#
# Frontend public vars live in `frontend/.env.example` → `frontend/.env.local`.

# Supabase — service role MUST stay server-side only (bypasses RLS).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — omit or set USE_MOCK_AI=true to bypass real calls in dev/tests.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
USE_MOCK_AI=false

# ElevenLabs — optional if you rely on mocked audio (/mock-interviewer.mp3 in `public/` + PUBLIC_APP_URL for absolute URLs).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Public absolute base for MOCK relative audio URLs (point at backend origin in dev, e.g. http://127.0.0.1:3001).
PUBLIC_APP_URL=http://127.0.0.1:3001

# PayHere — hosted checkout POST + Notify verification (MD5 per PayHere docs).
# Sandbox checkout base defaults in code when unset (see PAYHERE_CHECKOUT_BASE_URL below).
#
# Hosted Notify URL MUST be public HTTPS reachable by PayHere (sandbox + live cannot hit localhost directly).
# Point this to YOUR deployed `/api/payments/payhere/notify` endpoint, for example:
#   PAYHERE_NOTIFY_URL=https://your-production-domain.example/api/payments/payhere/notify
#
# Return/cancel URLs are customer browser redirects configured in YOUR PayHere checkout flow.
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_CHECKOUT_BASE_URL=https://sandbox.payhere.lk/pay/checkout

# Premium plan price surfaced to PayHere (string two-decimal amount is produced for signing).
PAYHERE_PREMIUM_AMOUNT=1999
PAYHERE_CURRENCY=LKR
PAYHERE_ORDER_TITLE=HireMind Premium plan

# Customer checkout fields (PayHere requires contact + address fields; provide safe defaults for testing).
PAYHERE_CHECKOUT_FIRST_NAME=HireMind
PAYHERE_CHECKOUT_LAST_NAME=Candidate
PAYHERE_CHECKOUT_FALLBACK_EMAIL=you@example.com
PAYHERE_CHECKOUT_PHONE=0770000000
PAYHERE_CHECKOUT_ADDRESS=N/A
PAYHERE_CHECKOUT_CITY=Colombo
PAYHERE_CHECKOUT_COUNTRY=LK

# Browser redirect targets after PayHere checkout (configure to your front-end routes).
PAYHERE_RETURN_URL=https://your-app.example/billing/success
PAYHERE_CANCEL_URL=https://your-app.example/billing/cancel

# Server notify callback (see note above).
PAYHERE_NOTIFY_URL=https://your-app.example/api/payments/payhere/notify
