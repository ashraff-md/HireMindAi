# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Dependencies ───────────────────────────────────────────────────────────────
node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/

# ── Next.js (workspace packages) ─────────────────────────────────────────────
**/.next/
**/out/

# ── Production bundles ─────────────────────────────────────────────────────────
build/
dist/

# ── Environment & secrets ──────────────────────────────────────────────────────
.env*
!.env.example
!**/.env.example

# ── Vercel ─────────────────────────────────────────────────────────────────────
.vercel/
**/.vercel/

# ── TypeScript / tooling caches ────────────────────────────────────────────────
*.tsbuildinfo
**/next-env.d.ts
.turbo/
.eslintcache
.prettiercache

# ── Logs ───────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── Supabase CLI local state ───────────────────────────────────────────────────
supabase/.branches/
supabase/.temp/

# ── Misc ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*.pem

# ── Patch / merge debris ───────────────────────────────────────────────────────
*.orig
*.rej

# ── Tool caches ────────────────────────────────────────────────────────────────
.cache/

# ── IDE (optional noise) ────────────────────────────────────────────────────────
.idea/
