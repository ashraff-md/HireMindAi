# Backend — copy to `.env.local` (do not commit secrets)

# Supabase (service role — server only)
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
# or
SUPABASE_URL=

# Google Gemini (AI interview + resume parsing)
GEMINI_API_KEY=
# Optional alias some teams use:
# GOOGLE_AI_API_KEY=
# Optional; default is gemini-2.0-flash (use gemini-1.5-flash if your project/API does not expose 2.x)
GEMINI_MODEL=

# Force deterministic mock text/JSON even when GEMINI_API_KEY is set
# USE_MOCK_AI=true

# ElevenLabs TTS (optional)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=

# Public URL for mock audio / assets
# PUBLIC_APP_URL=http://127.0.0.1:3001
