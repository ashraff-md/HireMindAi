# Backend — copy to `.env.local` (do not commit secrets)

# Supabase (service role — server only; required for interviews, webhooks, admin DB access)
# Dashboard: Project Settings → API → Project API keys → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
# or
SUPABASE_URL=

# Google Gemini (AI interview + resume parsing)
GEMINI_API_KEY=
# Optional alias some teams use:
# GOOGLE_AI_API_KEY=
# Optional model id (default gemini-1.5-flash). gemini-2.5-flash free tier is very small (~20 requests/day); the API retries once with 1.5-flash on 429, or set this explicitly / USE_MOCK_AI=true.
# GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL=

# Force deterministic mock text/JSON even when GEMINI_API_KEY is set
# USE_MOCK_AI=true

# ElevenLabs TTS (optional). Free tiers often get HTTP 402 on premade “library” voices — use an Instant Voice (your clone) ID,
# or upgrade. If ELEVENLABS_VOICE_ID is unset, TTS is skipped and placeholder audio is used (avoids a useless API call).
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=
# Public URL for mock audio / assets
# PUBLIC_APP_URL=http://127.0.0.1:3001

# Premium interview mic audio — filesystem (default: backend/data/interview-recordings)
# INTERVIEW_RECORDINGS_DIR=/var/hiremind/interview-recordings

# Payment gateway — to be implemented (checkout + webhook). See GET /api/payments/status.
# When integrated, add provider keys here and wire routes under backend/src/app/api/payments/
