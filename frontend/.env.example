# Frontend (Next.js — see `frontend/`)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Leave empty locally: `frontend/next.config.ts` rewrites `/api/*` → backend dev server.
NEXT_PUBLIC_API_URL=
# Force client mock pipeline even when signed in (useful for UI-only demos).
NEXT_PUBLIC_FORCE_MOCK_API=false
# Used only by `frontend/next.config.ts` rewrites (default http://127.0.0.1:3001).
BACKEND_DEV_URL=http://127.0.0.1:3001
